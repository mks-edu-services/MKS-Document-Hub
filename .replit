modules = ["nodejs-24"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 20878
externalPort = 3000

[userenv]

[userenv.shared]
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN = "mks-certificate-app-cbf64.firebaseapp.com"
EXPO_PUBLIC_FIREBASE_PROJECT_ID = "mks-certificate-app-cbf64"
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET = "mks-certificate-app-cbf64.firebasestorage.app"
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID = "813274492999"
EXPO_PUBLIC_FIREBASE_APP_ID = "1:813274492999:web:b93bbcf52fa5288db40162"
