{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "node ./scripts/preinstall.cjs",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "deploy:api": "node ./scripts/deploy-api.cjs",
    "deploy:web": "node ./scripts/deploy-web.cjs",
    "drive:template": "node ./scripts/drive-link-mapping.cjs export",
    "drive:import": "node ./scripts/drive-link-mapping.cjs import",
    "import:registry": "node ./scripts/import-registry.cjs",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "firebase-tools": "^15.19.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
